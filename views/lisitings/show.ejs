<% layout("/layouts/boilerplate") %>
<style>
  /* Custom Star Rating Style Fix */
  .rating-css input {
    display: none;
  }
  .rating-css label {
    color: #ccc; 
    cursor: pointer;
    font-size: 30px;
    margin: 0 2px;
    transition: color 0.2s ease;
  }
  /* flex-row-reverse ki wajah se hover aur selection ekdum sahi chalega */
  .rating-css input:checked ~ label,
  .rating-css input:hover ~ label {
    color: #ffc107 !important;
  }
  .rating-css label:hover ~ label {
    color: #ffc107 !important;
  }
</style>

<div class="row mt-3 justify-content-center px-2">
  <!-- Title Section -->
  <div class="col-12 col-md-8 text-center text-md-start">
    <h3>Listing details :</h3>
  </div>

  <!-- Main Listing Card -->
  <div class="card col-12 col-md-8 show-card shadow-sm p-0 mb-4">
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" style="height: 40vh; object-fit: cover; border-radius: 0.5rem 0.5rem 0 0;" />
    <div class="card-body p-3">
      <p class="card-text">
        <h4 class="mb-3"><b><%= listing.title %></b></h4>
        <ul class="list-unstyled-custom fs-5">
          <li class="mb-2"><i class="fa-solid fa-circle-info text-muted me-2"></i><%= listing.description %></li>
          <li class="mb-2"><i class="fa-solid fa-indian-rupee-sign text-muted me-2"></i><%= listing.price.toLocaleString("en-IN") %> / night</li>
          <li class="mb-2"><i class="fa-solid fa-location-dot text-muted me-2"></i><%= listing.location %></li>
          <li class="mb-2"><i class="fa-solid fa-earth-americas text-muted me-2"></i><%= listing.country %></li>
        </ul>
      </p>
    </div>
  </div>

  <!-- Admin/Owner Action Buttons -->
  <% if(currUser) { %>
    <% if((listing.owner && listing.owner._id.equals(currUser._id)) || currUser.username === 'abhiadmin') { %>
      <div class="col-12 col-md-8 d-flex justify-content-start gap-2 mb-4">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn px-4">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display: inline;">
          <button class="btn btn-danger px-4">Delete</button>
        </form>
      </div>
    <% } %>
  <% } %>

  <!-- CONATCT SECTION (AB LOOP SE BAHAR HAI - MOBILE MEIN 100% WIDTH LEGA) -->
  <div class="col-12 col-md-8 mb-4">
    <div class="contact-section p-3 border rounded bg-light shadow-sm">
        <h5 class="mb-3 text-start"><i class="fa-solid fa-address-book text-primary"></i> Interested in this room?</h5>
        <p class="mb-3 text-start"><strong>Owner Number:</strong> +91 <%= listing.contact %></p>
        
        <div class="d-flex flex-column flex-sm-row gap-2">
            <a href="tel:<%= listing.contact %>" class="btn btn-primary w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                <i class="fa-solid fa-phone"></i> Call Owner
            </a>
            <a href="https://wa.me/91<%= listing.contact %>?text=Hi,%20I%20am%20interested%20in%20your%20room%20'<%= listing.title %>'%20listed%20on%20AbhiRooms." 
               target="_blank" 
               class="btn btn-success w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                <i class="fa-brands fa-whatsapp"></i> Chat on WhatsApp
            </a>
        </div>
    </div>
  </div>

  <div class="col-12 col-md-8 mb-3">
    <hr />
    
    <!-- REVIEW FORM -->
    <% if(currUser) { %>
        <h4 class="mt-3">Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="mb-3 mt-3">
            <label class="form-label">Rating</label>
            <div class="rating-css d-flex flex-row-reverse justify-content-end">
                <input type="radio" value="5" name="review[rating]" id="rating5">
                <label for="rating5" class="fa-solid fa-star"></label>
                <input type="radio" value="4" name="review[rating]" id="rating4">
                <label for="rating4" class="fa-solid fa-star"></label>
                <input type="radio" value="3" name="review[rating]" id="rating3">
                <label for="rating3" class="fa-solid fa-star"></label>
                <input type="radio" value="2" name="review[rating]" id="rating2">
                <label for="rating2" class="fa-solid fa-star"></label>
                <input type="radio" value="1" name="review[rating]" id="rating1">
                <label for="rating1" class="fa-solid fa-star"></label>
            </div>
          </div>
          <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please submit some comments for review</div>
          </div>
          <button class="btn btn-outline-dark px-4">Submit</button>
        </form>
        <hr />
    <% } %>

    <!-- ALL REVIEWS SHOW SECTION -->
    <h4 class="mt-4">All Reviews</h4>
    <div class="row px-2">
      <% if(listing.reviews.length === 0) { %>
        <p class="text-muted ps-2">No reviews yet.</p>
      <% } %>
      
      <% for(let review of listing.reviews) { %>
        <div class="card col-12 col-md-5 m-2 p-3 border shadow-sm">
          <div class="card-body">
            <h5 class="card-title">@<%= review.author?.username || "Anonymous" %></h5>
            
            <p class="card-text text-warning my-2">
              <% for(let i=1; i<=5; i++) { %>
                <% if(i <= review.rating) { %>
                  <i class="fa-solid fa-star"></i>
                <% } else { %>
                  <i class="fa-regular fa-star text-muted"></i>
                <% } %>
              <% } %>
            </p>
            
            <p class="card-text text-secondary mb-3"><%= review.comment %></p>
            
            <% if(currUser) { %>
              <% if(currUser.username === 'abhiadmin' || (review.author && review.author._id.equals(currUser._id))) { %>
                <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="m-0">
                  <button class="btn btn-sm btn-dark px-3">Delete</button>
                </form>
              <% } %>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>