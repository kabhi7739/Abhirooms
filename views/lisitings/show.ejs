<% layout("/layouts/boilerplate") %>
<style>
  /* Custom Star Rating Style */
  .rating-css {
    color: #ffe400;
    font-size: 24px;
    font-family: sans-serif;
  }
  .rating-css input {
    display: none;
  }
  .rating-css input + label {
    font-size: 30px;
    text-shadow: 1px 1px 0 #ffe400;
    cursor: pointer;
  }
  .rating-css input:checked ~ input + label {
    color: #ccc;
  }
</style>
</style>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3>Listing details :</h3>
  </div>

  <div class="card col-6 offset-3 show-card">
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" />
    <div class="card-body">
      <p class="card-text">
        <b><%= listing.title %></b> <br>
        <li><%= listing.description %></li> <br>
        <li>&#8377;<%= listing.price.toLocaleString("en-IN") %></li><br>
        <li><%= listing.location %></li><br>
        <li><%= listing.country %></li>
      </p>
    </div>
  </div>

  <br />
  <div class="btns offset-3 col-6 mb-3">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>

    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display: inline;" class="ms-3">
      <button class="btn btn-danger">Delete</button>
    </form>
  </div>

  <div class="col-6 offset-3 mb-3">
    <hr />
    
    <style>
      .rating-css input {
        display: none;
      }
      .rating-css input + label {
        font-size: 30px;
        color: #ffe400;
        cursor: pointer;
      }
      .rating-css input:checked ~ input + label {
        color: #ccc;
      }
    </style>

    <h4>Leave a Review</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
      
      <div class="mb-3 mt-3">
        <label class="form-label">Rating</label>
        <div class="rating-css d-flex flex-row-reverse justify-content-end">
          <input type="radio" value="5" name="review[rating]" id="rating5">
          <label for="rating5" class="fa-solid fa-star"></label>
          <input type="radio" value="4" name="review[rating]" id="rating4">
          <label for="rating4" class="fa-solid fa-star"></label>
          <input type="radio" value="3" name="review[rating]" id="rating3" checked>
          <label for="rating3" class="fa-solid fa-star"></label>
          <input type="radio" value="2" name="review[rating]" id="rating2">
          <label for="rating2" class="fa-solid fa-star"></label>
          <input type="radio" value="1" name="review[rating]" id="rating1">
          <label for="rating1" class="fa-solid fa-star"></label>
        </div>
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
        <div class="invalid-feedback">Please submit some comments for review</div>
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>

  <hr />
  
  

  
    <hr />

    <h4>All Reviews</h4>
    <div class="row">
      <% for(let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3 p-3">
          <div class="card-body">
            <h5 class="card-title">Anonymous User</h5>
            <p class="card-text"><%= review.comment %></p>
            
            <p class="card-text text-warning">
              <% for(let i=1; i<=5; i++) { %>
                <% if(i <= review.rating) { %>
                  <i class="fa-solid fa-star"></i>
                <% } else { %>
                  <i class="fa-regular fa-star text-muted"></i>
                <% } %>
              <% } %>
            </p>
            
            <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-dark">Delete</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div> 