<% layout("/layouts/boilerplate") %>

<div class="container mt-5">
    <div class="row">
        <!-- Left Side: User Card -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <div class="profile-avatar mb-3 mx-auto" style="width: 80px; height: 80px; background-color: #ff385c; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold;">
                    <%= user.username.charAt(0).toUpperCase() %>
                </div>
                <h3><%= user.username %></h3>
                <p class="text-muted mb-2"><%= user.email %></p>
                <p class="small text-muted">Member Since: <%= new Date(user.createdAt).toLocaleDateString() %></p>
                <hr>
                <a href="/logout" class="btn btn-outline-danger btn-sm w-100">Log Out</a>
            </div>
        </div>

        <!-- Right Side: User Listings -->
        <div class="col-md-8">
            <h3 class="mb-4">Your Hosted Properties</h3>
            <% if(myListings.length === 0) { %>
                <div class="alert alert-light border text-center p-4" role="alert">
                    <h5>No Rooms Hosted Yet!</h5>
                    <p class="text-muted small">List your space on Abhirooms.com and start earning.</p>
                    <a href="/listings/new" class="btn btn-sm btn-danger mt-2">Create Listing</a>
                </div>
            <% } else { %>
                <div class="row">
                    <% for(let listing of myListings) { %>
                        <div class="col-md-6 mb-3">
                            <div class="card h-100 shadow-sm border-0">
                                <img src="<%= listing.image.url %>" class="card-img-top" style="height: 160px; object-fit: cover;">
                                <div class="card-body p-3">
                                    <h5 class="card-title text-truncate" style="max-width: 100%;"><%= listing.title %></h5>
                                    <p class="card-text text-muted">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
                                    <div class="d-flex justify-content-between mt-3">
                                        <a href="/listings/<%= listing._id %>" class="btn btn-sm btn-dark px-3">View</a>
                                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-secondary px-3">Edit</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>